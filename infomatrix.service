[Unit]
Description=INFOMATRIX Robot Football Competition System
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/infomatrix
EnvironmentFile=-/home/ubuntu/infomatrix/.env
ExecStart=/usr/bin/node /home/ubuntu/infomatrix/server.js
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal
SyslogIdentifier=infomatrix

[Install]
WantedBy=multi-user.target
